  "components": {
    "schemas": {
      "CompetitionModel": {
        "required": [
          "id",
          "startedOn",
          "state",
          "mapName",
          "trackName",
          "trackId",
          "mapId"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "startedOn": {
            "type": "string",
            "format": "date-time"
          },
          "state": {
            "$ref": "#/components/schemas/CompetitionState"
          },
          "mapName": {
            "type": "string"
          },
          "trackName": {
            "type": "string"
          },
          "trackId": {
            "type": "integer",
            "format": "int32"
          },
          "mapId": {
            "type": "integer",
            "format": "int32"
          },
          "quadOfTheDay": {
            "type": [
              "null",
              "string"
            ]
          },
          "leagues": {
            "$ref": "#/components/schemas/LeagueOptions"
          }
        }
      },
      "CompetitionState": {
        "type": "integer"
      },
      "DashboardModel": {
        "required": [
          "leaderboard",
          "seasonLeaderboard"
        ],
        "type": "object",
        "properties": {
          "competition": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CompetitionModel"
              }
            ]
          },
          "leaderboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeagueLeaderboardModel"
            }
          },
          "seasonLeaderboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeagueSeasonLeaderboard"
            }
          }
        }
      },
      "LeagueLeaderboardModel": {
        "required": [
          "results"
        ],
        "type": "object",
        "properties": {
          "league": {
            "type": [
              "null",
              "string"
            ]
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeaderboardResultModel"
            }
          }
        }
      },
      "LeaderboardResultModel": {
        "required": [
          "playerName",
          "country"
        ],
        "type": "object",
        "properties": {
          "playerName": {
            "type": "string"
          },
          "trackTime": {
            "type": "integer",
            "format": "int32"
          },
          "localRank": {
            "type": "integer",
            "format": "int32"
          },
          "globalRank": {
            "type": "integer",
            "format": "int32"
          },
          "modelName": {
            "type": [
              "null",
              "string"
            ]
          },
          "country": {
            "type": "string"
          }
        }
      },
      "LeagueSeasonLeaderboard": {
        "required": [
          "results"
        ],
        "type": "object",
        "properties": {
          "league": {
            "type": [
              "null",
              "string"
            ]
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeasonResult"
            }
          }
        }
      },
      "SeasonResult": {
        "required": [
