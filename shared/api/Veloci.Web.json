          "othersName": {
            "type": "string"
          },
          "definitions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LeagueDescriptor"
            }
          }
        }
      },
      "LeagueDescriptor": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "order": {
            "type": "integer",
            "format": "int32"
          },
          "color": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
