            "format": "date-time"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "PilotProfileModel": {
        "required": [
          "name",
          "country",
          "currentDayStreak",
          "maxDayStreak",
          "achievements",
          "totalRaceDays",
          "availableFreezes",
          "globalRating",
          "ratingHistory"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "currentDayStreak": {
            "type": "integer",
            "format": "int32"
          },
          "maxDayStreak": {
            "type": "integer",
            "format": "int32"
          },
          "achievements": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PilotAchievementModel"
            }
          },
          "totalRaceDays": {
            "type": "integer",
            "format": "int32"
          },
          "lastRaceDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "firstRaceDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "availableFreezes": {
            "type": "integer",
            "format": "int32"
          },
          "globalRating": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "league": {
            "type": [
              "null",
              "string"
            ]
          },
          "leagueColor": {
            "type": [
              "null",
              "string"
            ]
          },
          "ratingHistory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PilotRatingHistoryPoint"
            }
          }
        }
      },
      "PilotRatingHistoryPoint": {
        "required": [
          "date",
          "rank"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "gapPercent": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "rank": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PilotResult": {
        "required": [
          "date",
          "points",
          "trackTime"
        ],
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "points": {
            "type": "integer",
            "format": "int32"
          },
          "trackTime": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RatingModel": {
        "required": [
          "calculatedOn",
          "ratings",
          "droppedOutPilots"
        ],
        "type": "object",
        "properties": {
          "calculatedOn": {
            "type": "string",
            "format": "date-time"
          },
          "ratings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PilotRatingModel"
            }
          },
          "droppedOutPilots": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PilotRatingModel"
            }
          }
        }
      },
      "PilotRatingModel": {
        "required": [
          "pilotId",
          "pilotName",
          "rank"
        ],
        "type": "object",
        "properties": {
          "pilotId": {
            "type": "integer",
            "format": "int32"
          },
          "pilotName": {
            "type": "string"
          },
          "country": {
            "type": [
              "null",
              "string"
            ]
          },
          "averageGapPercent": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "averageGapChange": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "rank": {
            "type": "integer",
            "format": "int32"
          },
          "rankChange": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
