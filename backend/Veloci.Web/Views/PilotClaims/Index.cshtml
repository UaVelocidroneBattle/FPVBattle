@using Veloci.Web.Controllers.PilotClaims
@model PilotClaimsViewModel

@{
    ViewData["Title"] = "Pilot Claims";
}

<h1>Pilot Claims</h1>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (Model.Claims.Count == 0)
{
    <p class="text-muted">There are no pending claims.</p>
}
else
{
    <table class="table table-bordered w-auto">
        <thead>
            <tr>
                <th>User</th>
                <th>Name</th>
                <th>Claimed Pilot</th>
                <th>Created</th>
                <th>Expires</th>
                <th>Status</th>
                <th>Pilot</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var claim in Model.Claims)
            {
                <tr>
                    <td>@claim.UserEmail</td>
                    <td>@(claim.UserName ?? "—")</td>
                    <td>@claim.PilotName</td>
                    <td>@claim.CreatedOn.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@claim.ExpiresOn.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (claim.IsExpired)
                        {
                            <span class="badge bg-secondary">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        @if (!claim.PilotExists)
                        {
                            <span class="text-muted">no results yet</span>
                        }
                        else if (claim.PilotLinked)
                        {
                            <span class="text-danger">linked to another user</span>
                        }
                        else
                        {
                            <span class="text-success">available</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            @if (claim.CanApprove)
                            {
                                <form asp-action="Approve" method="post">
                                    <input type="hidden" name="claimId" value="@claim.ClaimId" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                            }
                            <form asp-action="Delete" method="post">
                                <input type="hidden" name="claimId" value="@claim.ClaimId" />
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
