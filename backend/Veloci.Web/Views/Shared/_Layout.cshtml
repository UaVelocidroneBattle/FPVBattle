<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — FPV Battle Flight Control</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Veloci.Web.styles.css" asp-append-version="true"/>
</head>
<body>
@{
    var currentController = ViewContext.RouteData.Values["controller"] as string;

    string Active(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<div class="app">
    <aside class="sidebar">
        <a class="brand" asp-controller="Home" asp-action="Index">
            FPV BATTLE
            <span>FLIGHT CONTROL</span>
        </a>
        <nav>
            <div class="nav-label">Competition</div>
            <a class="side-link @Active("TrackQueue")" asp-controller="TrackQueue" asp-action="Index">Track Queue</a>
            <a class="side-link @Active("Whitelist")" asp-controller="Whitelist" asp-action="Index">Whitelist</a>

            <div class="nav-label">Pilots</div>
            <a class="side-link @Active("UserPilots")" asp-controller="UserPilots" asp-action="Index">User Pilots</a>
            <a class="side-link @Active("PilotClaims")" asp-controller="PilotClaims" asp-action="Index">Pilot Claims</a>

            <div class="nav-label">System</div>
            <a class="side-link" href="/hangfire">Hangfire</a>
        </nav>
    </aside>
    <div class="main">
        <header class="topbar">
            <h1>@ViewData["Title"]</h1>
            <partial name="_LoginPartial"/>
        </header>
        <main role="main" class="content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
