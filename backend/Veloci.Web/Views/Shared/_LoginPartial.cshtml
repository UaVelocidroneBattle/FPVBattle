@using Microsoft.AspNetCore.Identity
@using Veloci.Data.Domain
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="user-box">
    @if (SignInManager.IsSignedIn(User))
    {
        <a class="user-chip" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage account">@User.Identity?.Name</a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn-link-quiet">Sign out</button>
        </form>
    }
    else
    {
        <a class="user-chip" asp-area="Identity" asp-page="/Account/Register">Register</a>
        <a class="btn btn-primary btn-sm" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
    }
</div>
