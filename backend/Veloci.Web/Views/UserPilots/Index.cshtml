@using Veloci.Web.Controllers.UserPilots
@model UserPilotsViewModel

@{
    ViewData["Title"] = "User Pilots";
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<section class="panel">
    <header class="panel-head">
        <h2 class="panel-title">Link User to Pilot</h2>
    </header>
    <div class="panel-body">
        @if (!Model.UnlinkedUsers.Any())
        {
            <span class="text-muted">All users are already linked to a pilot.</span>
        }
        else
        {
            <form asp-action="Link" method="post" class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label mb-1">User</label>
                    <select name="userId" class="form-select w-auto" required>
                        @foreach (var user in Model.UnlinkedUsers)
                        {
                            <option value="@user.UserId">@user.Email</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label mb-1">Pilot Name <span class="text-muted">(exact, case sensitive)</span></label>
                    <input type="text" name="pilotName" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary">Link</button>
            </form>
        }
    </div>
</section>

<section class="panel">
    <header class="panel-head">
        <h2 class="panel-title">Connections</h2>
        <span class="panel-count">@Model.Users.Count</span>
    </header>
    @if (Model.Users.Count == 0)
    {
        <div class="panel-body text-muted">No users registered yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Display Name</th>
                        <th>Pilot</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="mono">@user.Email</td>
                            <td>@(user.DisplayName ?? "—")</td>
                            <td class="mono">@(user.PilotName ?? "—")</td>
                            <td class="text-end">
                                @if (user.PilotName is not null)
                                {
                                    <form asp-action="Unlink" method="post">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn btn-sm btn-danger">Unlink</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
